# Lincoln Credentials (required for runner)
LINCOLN_LOGIN_ID=
LINCOLN_LOGIN_PW=

# Supabase (required for web + runner)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Playwright (runner)
PLAYWRIGHT_HEADLESS=false

# Retry (runner, default: 3)
RETRY_MAX_ATTEMPTS=3

# 2FA timeout in ms (runner, default: 300000 = 5 min)
TWO_FACTOR_TIMEOUT_MS=300000
